# Exclusions used by the API server Dockerfile build. The docker-compose
# build context is the repository root, so we aggressively prune anything
# the API image does not need.

# Local npm installs — the Dockerfile runs npm ci fresh inside the image.
**/node_modules
**/.npm

# Build outputs — regenerated by the builder stage.
**/dist
**/build
**/.next
**/.vite

# Client is not needed for the API image. Only the client/package.json
# is copied for workspace resolution (handled explicitly in the Dockerfile).
client/src
client/public
client/index.html
client/vite.config.ts
client/tsconfig*.json
client/tailwind.config.*
client/postcss.config.*

# Environment + secrets.
.env
.env.*
!.env.example
server/.env
client/.env

# Git + Claude metadata.
.git
.gitignore
.github
.claude
.cursor

# IDE / OS.
.vscode
.idea
.DS_Store
*.log
logs

# Docs + generated artefacts.
docs
n8n-workflows
SJMS-2.5-Build-Plan.docx

# Docker itself (prevent recursive context explosion).
Dockerfile
**/Dockerfile*
.dockerignore
docker-compose*.yml
docker/
